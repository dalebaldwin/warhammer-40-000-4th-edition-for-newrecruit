              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="15"/>
              </costs>
              <rules>
                <rule name="Skyleap" id="4f32-4d8e-4814-45b8" hidden="false">
                  <description>The player may elect to remove a unit with Skyleap form the table in its Movement phase, placing it in Reserve. If the squad was engaged in combat, the enemy may make a 3&quot; consolidation move. The squad may then Deep Strike back into play from their following turn, exactly if they had been held in reserve from the beginning of the game (even in missions that do not allow Deep Strike or reserves). For example, if they are removed from the table on turn 2, they will re-enter play on turn 3 on a roll of a 3+.</description>
                </rule>
              </rules>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Intercept" hidden="false" id="444c-1c57-3f1f-344c">
