      <modifiers>
        <modifier type="set" value="true" field="hidden">
          <conditionGroups>
            <conditionGroup type="or">
              <conditions>
                <condition type="atLeast" value="6" field="selections" scope="root-entry" childId="83af-8999-54fb-a887" shared="true"/>
                <condition type="atLeast" value="13" field="selections" scope="root-entry" childId="model" shared="true"/>
              </conditions>
