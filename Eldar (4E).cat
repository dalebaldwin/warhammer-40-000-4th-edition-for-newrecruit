    <selectionEntry type="upgrade" import="true" name="Swooping Hawk Wings" hidden="false" id="7850-c835-379a-65b7">
      <modifiers>
        <modifier type="set" value="Jump Infantry" field="556e6974205479706523232344415441232323" scope="parent" affects="profiles.Unit"/>
      </modifiers>
      <profiles>
        <profile name="Swooping Hawk Wings" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="be7e-6a63-c186-7e9b">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model with Swooping Hawk Wings moves as if it is equipped with a jump pack and may use the Deep Strike rules to deploy in mission that allow it.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Deep Strike" id="fb1e-16f8-0b10-6e94" hidden="false" type="rule" targetId="bbf5-b1c2-49b0-f3c2"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Warp Jump Generator" hidden="false" id="bef0-20db-c81b-34e9">
      <modifiers>
        <modifier type="set" value="Jump Infantry" field="556e6974205479706523232344415441232323" scope="parent" affects="profiles.Unit"/>
      </modifiers>
      <infoLinks>
        <infoLink name="Deep Strike" id="110d-f063-d1e7-a3d9" hidden="false" type="rule" targetId="bbf5-b1c2-49b0-f3c2"/>
      </infoLinks>
      <profiles>
        <profile name="Warp Jump Generator" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="fb44-0eea-e221-818e">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A unit with warp jump generators moves as if it was equipped with jump packs. If unengaged, the unit may make a second jump during the assault phase instead of assaulting. Nominate the direction the unit is jumping in and move it up to 2D6&quot; in this direction. Any model finishing its move in impassable terrain is destroyed. If you roll a double, one member of the unit has been claimed by the Warp and is removed as a casualty (the survivors move up to the distance rolled, following the normal rules for jump infantry).</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Banshee Mask" hidden="false" id="59d2-1bb9-de96-5735">
      <profiles>
        <profile name="Banshee Mask" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="f469-6742-dd9b-7951">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">In the first round of an assault a model wearing a Banshee mask has Initiative 10 and negates any Initiative bonus conferred by cover and grenades.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Mandiblasters" hidden="false" id="41ca-9261-39bf-da26">
      <profiles>
        <profile name="Mandiblasters" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="9656-c5ac-c188-3892">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model with Mandiblasters has +1 Attack.
In NewRecruit this modifier is applied to the profile automatically.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="increment" value="1" field="4.123232344415441e+21" scope="parent" affects="profiles.Unit"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Scorpion Chainsword" hidden="false" id="352e-8969-a1d4-e1c2">
      <profiles>
        <profile name="Scorpion Chainsword" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="3263-e853-6cd8-959e">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">This is a one-handed weapon that adds +1 S to the model&apos;s attacks.
In NewRecruit this modifier is applied to the profile automatically.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="increment" value="1" field="5.323232344415441e+21" scope="parent" affects="profiles.Unit"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Laser Lance" hidden="false" id="49bc-df0a-011c-352e">
      <profiles>
        <profile name="Laser Lance" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="2564-8906-4e30-ec3c">
          <characteristics>
            <characteristic name="Range" typeId="52616e676523232344415441232323">6&quot;</characteristic>
            <characteristic name="Strength" typeId="537472656e67746823232344415441232323">6</characteristic>
            <characteristic name="AP" typeId="4.1502323234441545e+23">4</characteristic>
            <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 1, Lance</characteristic>
            <characteristic name="Info" typeId="33e9-27bd-77e4-401d">A Laser Lance may be used as a ranged weapon with this profile.</characteristic>
          </characteristics>
        </profile>
        <profile name="Laser Lance" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="c454-327a-56d1-f4e2">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">On any turn in which they initiate an assault, models armed with laser lances count as having Strength 6 power weapons. They may also be used as ranged weapons with the related profile.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
