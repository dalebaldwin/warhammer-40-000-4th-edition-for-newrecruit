    <selectionEntry type="model" import="true" name="The Avatar of Khaine" hidden="false" id="a181-9d61-7bd4-eafc">
      <categoryLinks>
        <categoryLink name="HQ" hidden="false" id="0706-21ff-1b43-8d21" targetId="0d45-9523-cfd8-4efd" primary="true"/>
        <categoryLink name="Character" hidden="false" id="6ff8-764c-1385-99e1" targetId="c918-96c1-1ff1-3df1" primary="false"/>
      </categoryLinks>
      <profiles>
        <profile name="The Avatar of Khaine" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="53fb-7f0d-9c1f-67f1">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Monstrous Creature</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">10</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">5</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">6</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">6</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">4</characteristic>
            <characteristic name="I" typeId="4.923232344415441e+21">6</characteristic>
            <characteristic name="A" typeId="4.123232344415441e+21">4</characteristic>
            <characteristic name="LD" typeId="4c4423232344415441232323">10</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">3+</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Daemon" id="f434-875d-40b9-c7a8" hidden="false">
          <description>For all intents and purposes the Avatar is a Daemon and will therefore be affected by weapons and abilities that affect Daemons. He benefits from a 4+ Invulnerable Save as well as his 3+ Armour Save.</description>
        </rule>
        <rule name="Inspiring" id="69d3-3172-3c48-b59f" hidden="false">
          <description>Any Eldar unit with a model within 12&quot; of the Avatar becomes Fearless.</description>
        </rule>
        <rule name="Molten Body" id="4002-407e-376b-c7af" hidden="false">
          <description>Melta weapons, flamers and heavy flamers cannot wound the Avatar.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Fearless" id="fbc8-5390-b03d-d26d" hidden="false" type="rule" targetId="db33-1068-512b-6958"/>
      </infoLinks>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="The Wailing Doom" hidden="false" id="3e0c-60a2-f5cb-1999">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="0a49-d21a-b0c9-18b2-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0a49-d21a-b0c9-18b2-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="The Wailing Doom" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="2177-39b3-421c-aa0d">
              <characteristics>
                <characteristic name="Range" typeId="52616e676523232344415441232323">12&quot;</characteristic>
                <characteristic name="Strength" typeId="537472656e67746823232344415441232323">8</characteristic>
                <characteristic name="AP" typeId="4.1502323234441545e+23">1</characteristic>
                <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 1, Melta</characteristic>
                <characteristic name="Info" typeId="33e9-27bd-77e4-401d">The Wailing Doom is a weapon of immense power that may take the form of a vicious spear, a mighty sword, or a many-bladed axe. It can be used to project a nimbus of burning psychic energy, with the listed profile.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="155"/>
      </costs>
    </selectionEntry>
  </selectionEntries>
  <sharedSelectionEntryGroups>
    <selectionEntryGroup name="Transport" id="0825-f8ff-182e-4e81" hidden="false">
      <entryLinks>
        <entryLink import="true" name="Wave Serpent" hidden="false" id="9487-56d4-5a7e-fdb5" type="selectionEntry" targetId="fc50-1af9-74cc-2ae1">
          <rules>
            <rule name="Energy Field" id="2899-7515-76e3-92c7" hidden="false">
              <description>Any ranged attack against the Wave Serpent from the front or side arc with a Strength of greater than 8 counts as S8. In addition, all ranged attacks never roll more than +1D6 for their armour penetration (for example, Melta weapons at half range or ordance only roll one dice). Attacks in close combat, or from the rear, are unaffected by the energy field rule.</description>
            </rule>
          </rules>
          <profiles>
            <profile name="Wave Serpent" typeId="307d-047f-ca13-706b" typeName="Transport" hidden="false" id="eba0-4bd5-bb22-dcfd">
              <characteristics>
                <characteristic name="Capacity" typeId="8285-4205-b6cd-8473">12 infantry, or 5 Wrathguard and 2 characters</characteristic>
                <characteristic name="Fire Points" typeId="b270-a7f9-22b2-3702">None</characteristic>
                <characteristic name="Access Points" typeId="d17b-0342-b1dc-b8e7">Rear</characteristic>
              </characteristics>
            </profile>
            <profile name="Wave Serpent" typeId="56656869636c6523232344415441232323" typeName="Vehicle" hidden="false" id="bf0a-0d36-9817-1e37">
              <characteristics>
                <characteristic name="Front" typeId="46726f6e7423232344415441232323">12</characteristic>
                <characteristic name="Side" typeId="5.369646523232344e+27">12</characteristic>
                <characteristic name="Rear" typeId="5.265617223232345e+27">10</characteristic>
                <characteristic name="BS" typeId="a6a5-1595-da9e-6155">3</characteristic>
                <characteristic name="Type" typeId="5.479706523232345e+27">Tank, Fast, Skimmer</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <selectionEntryGroups>
            <selectionEntryGroup name="Turret-mounted Main Weapon" id="db15-0521-74b9-d281" hidden="false"/>
            <selectionEntryGroup name="Hull Weapon" id="fe4e-5682-800c-6198" hidden="false" defaultSelectionEntryId="af62-97b9-d00a-3152">
              <entryLinks>
                <entryLink import="true" name="Shuriken Cannon" hidden="false" id="2f88-549b-9df7-5810" type="selectionEntry" targetId="8c91-f646-f1fd-b315" sortIndex="2">
                  <costs>
                    <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
                  </costs>
                </entryLink>
                <entryLink import="true" name="Shuriken Catapult" hidden="false" id="e700-591c-e7c5-9344" type="selectionEntry" targetId="e564-1262-1623-a522" sortIndex="1">
                  <modifiers>
                    <modifier type="prepend" value="Twin-linked" field="name"/>
                    <modifier type="prepend" value="Twin-linked" field="name" affects="profiles.Weapon"/>
                    <modifier type="append" value="Twin-linked" field="8b10-045a-f593-605e" affects="profiles.Weapon" join=", "/>
                  </modifiers>
                </entryLink>
              </entryLinks>
              <constraints>
                <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="e4ff-c414-43d7-81ec-min" includeChildSelections="false" automatic="true"/>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e4ff-c414-43d7-81ec-max" includeChildSelections="false" automatic="true"/>
              </constraints>
