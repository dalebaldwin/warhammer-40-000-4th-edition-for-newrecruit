      <rules>
        <rule name="Masters of Stealth" id="rng01-mos-rule" hidden="false">
          <description>Rangers have the Infiltrate, Move Through Cover, and Stealth universal special rules.</description>
        </rule>
        <rule name="Pathfinders" id="rng01-path-rule" hidden="true">
          <description>Pathfinders have an improved cover save of 2+ instead of the normal value. In addition, any To Hit roll of a 6 by a Pathfinder with a ranger long rifle is AP1.</description>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="rng01-pf-01" shared="true" includeChildSelections="true"/>
