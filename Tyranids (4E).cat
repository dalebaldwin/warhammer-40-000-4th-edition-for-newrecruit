      <infoLinks>
        <infoLink name="Fearless" id="728a-663c-4996-85f9" hidden="false" type="rule" targetId="db33-1068-512b-6958"/>
      </infoLinks>
      <selectionEntries>
        <selectionEntry type="unit" import="true" name="Tyrant Guard Retinue" hidden="false" id="9608-95b3-c2c9-be1c">
          <selectionEntries>
            <selectionEntry type="model" import="true" name="Tyrant Guard" hidden="false" id="f3d6-8057-0be0-c3e1">
              <profiles>
                <profile name="Tyrant Guard" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="e303-f218-8ac1-2e01">
                  <characteristics>
                    <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Infantry</characteristic>
                    <characteristic name="WS" typeId="5.753232323444154e+23">5</characteristic>
