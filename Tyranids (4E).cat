    <selectionEntry type="upgrade" import="true" name="Lash Whip" hidden="false" id="fc83-f8a5-d3cd-2cd5">
      <profiles>
        <profile name="Lash Whip" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="51e2-ecf6-8490-c716">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">Models in base contact with a creature equipped with a lash whip lose one attack in each Assault phase (to a minimum of 1).</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Close Combat Biomorph" id="d456-f354-b3df-5077" hidden="false" type="rule" targetId="42c0-5486-5159-916f"/>
