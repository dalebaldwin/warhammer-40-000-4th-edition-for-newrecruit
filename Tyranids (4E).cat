  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Acid Maw" hidden="false" id="0427-f0c5-eca7-d2c7">
      <profiles>
        <profile name="Acid Maw" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="78c2-90d5-807a-87ec">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A creature with an acid maw may reroll unsuccessful rolls to wound in the first round of a close combat.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="415c-37ed-12ec-aa64" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Adrenal Glands (+1 I)" hidden="false" id="4a5d-368b-a400-259f">
      <profiles>
        <profile name="Adrenal Glands (+1 I)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="8149-02ef-2634-b0c0">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Adrenal glands add +1 to a creature&apos;s Weapon Skill or Initiative characteristics.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5d20-3b89-54a2-4230" includeChildSelections="false" automatic="true"/>
      </constraints>
      <modifiers>
        <modifier type="increment" value="1" field="4.923232344415441e+21" affects="profiles.Unit" scope="parent"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Bio-Plasma" hidden="false" id="3016-3c76-065a-dbc6">
      <profiles>
        <profile name="Bio-Plasma" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="a789-819b-f8f9-6681">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Creatures with bio-plasma may make a single extra close combat attack, worked out at double the model&apos;s Initiative (ie, Initiative 8 for a Gargoyle, etc). The bio-plasma hits on a roll of 4+ on a D6 regardless of the target type or WS. It inflicts a single hit with a Strength equal to the creature +1 (to a maximum of 10) - this hit is unaffected by the benefits of the Monstrous Creature special rule. Any casualties caused by the bio-plasma do count for combat resolution.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="8d26-30d1-a9a8-8cbc" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Bonded Exoskeleton (+1 T)" hidden="false" id="e2fa-6be4-1b72-fc1f">
      <profiles>
        <profile name="Bonded Exoskeleton (+1 T)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="0bc6-8c66-3288-6947">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A creature with a bonded exoskeleton gains +1 Toughness.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d199-7c85-932b-4f83" includeChildSelections="false" automatic="true"/>
      </constraints>
      <modifiers>
        <modifier type="increment" value="1" field="5.423232344415441e+21" affects="profiles.Unit" scope="parent"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Enhanced Senses (+1 BS)" hidden="false" id="c7bc-0c96-23df-f709">
      <profiles>
        <profile name="Enhanced Senses (+1 BS)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="c1ef-55a1-8caa-61cd">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Creatures with enhanced sense gain +1 Ballistic Skill.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5e18-d528-0bb6-f420" includeChildSelections="false" automatic="true"/>
      </constraints>
      <modifiers>
        <modifier type="increment" value="1" field="4.2532323234441546e+23" affects="profiles.Unit" scope="parent"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Extended Carapace (+1 Sv)" hidden="false" id="3607-cc27-a3d8-5307">
      <profiles>
        <profile name="Extended Carapace (+1 Sv)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="6e99-cc18-ab7b-ac1a">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A Tyranid with an extended carapce gains +1 to its Armour Saving throw. So a Tyranid with a 5+ Armour Save will have a 4+ Armour Save instead and so on. The Armour Save can not be improved better than 2+.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d9b8-4289-0dc1-1923" includeChildSelections="false" automatic="true"/>
      </constraints>
      <modifiers>
        <modifier type="decrement" value="1" field="5.361766523232344e+27" affects="profiles.Unit" scope="parent">
          <conditions>
            <condition type="equalTo" value="0" field="selections" scope="parent" childId="f4f9-7eee-0a6a-5df0" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
        <modifier type="set" value="0" field="d9b8-4289-0dc1-1923">
          <conditionGroups>
            <conditionGroup type="or">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="f3f6-6d57-f13e-cef4" shared="true"/>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="f52f-f084-c7c1-fe2a" shared="true"/>
              </conditions>
            </conditionGroup>
          </conditionGroups>
        </modifier>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Feeder Tendrils" hidden="false" id="f872-9b33-0ef4-d9c3">
      <profiles>
        <profile name="Feeder Tendrils" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="3c92-fa60-30f2-360d">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A creature with feeder tendrils always counts as having the Preferred Enemy special rule. Any Tyranid brood with a model within 2&quot; of the creature also benefits from the Preferred Enemy special rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f978-0993-bd5e-01ad" includeChildSelections="false" automatic="true"/>
      </constraints>
      <infoLinks>
        <infoLink name="Preferred Enemy" id="3040-1b49-0288-6188" hidden="false" type="rule" targetId="b6b9-28e7-4a3f-5334"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Flesh Hooks" hidden="false" id="930c-2455-48b4-824e">
      <profiles>
        <profile name="Flesh Hooks" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="fce8-abb3-10e8-eb5b">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A creature with flesh hooks counts as being equipped with frag grenades in close combat. Creatures with flesh hooks count &apos;vertically impassable&apos; pieces of terrain such as high walls or cliffs as difficult terrain instead.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="b4aa-17ef-91d2-7140" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Implant Attack" hidden="false" id="c79d-7596-c19a-65c2">
      <profiles>
        <profile name="Implant Attack" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="bffe-4bc4-c374-7dfc">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model that does not pass a Saving Throw when wounded by a creature with an implant attack suffers two wounds instead of one. Implant attacks are only effective in close combat and have no effect on wounds inflicted by bio-plasma.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="26f2-696b-0803-6e4c" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Leaping" hidden="false" id="6f5a-3ab6-cc7c-fa78">
      <profiles>
        <profile name="Leaping" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="d910-8cae-b5fb-a548">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Leaping creatures gain a Fast Charge of 12&quot;, though they do not become Beasts. A creature with Leaping may make its full attacks when within 3&quot; of  friendly model in base contact with the enemy rather than the usual 2&quot;.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="fcdd-589e-da7f-1707" includeChildSelections="false" automatic="true"/>
      </constraints>
      <modifiers>
        <modifier type="set" value="0" field="fcdd-589e-da7f-1707">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="parent" childId="f52f-f084-c7c1-fe2a" shared="true"/>
          </conditions>
        </modifier>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Mace Tail" hidden="false" id="9db8-3f54-d09d-129e">
      <profiles>
        <profile name="Mace Tail" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="6aeb-9c2e-5fac-7422">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A creature with a mace or scythe tail may make a special close combat attack each turn if more than four enemy models are in base contact with it at the beginning of that Assault phase. This is conducted at Initiative 1 and is resolved according to the type of the biomorph chosen.
A Mace tail gets 1 attack at the creature&apos;s full Strength.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3717-e9ef-3fe7-8879" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Regenerate" hidden="false" id="4666-2e0c-f186-506a">
      <profiles>
        <profile name="Regenerate" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="b830-06ef-23b7-52ce">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">At the start of each Tyranid turn a surviving model with regenerate rolls a dice for each wound it has lost, and for each 6 rolled that creature regains one lost wound, up to its starting total.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="125f-cf33-aadc-0f5f" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Reinforced Chitin (+1 W)" hidden="false" id="06e7-99ab-6f47-6966">
      <profiles>
        <profile name="Reinforced Chitin (+1 W)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="1b10-2b19-8ea4-4127">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Tyranids with reinforced chitin gain +1 Wound.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="7c64-0a7f-4c50-3563" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Scuttlers" hidden="false" id="60ef-a30e-3726-d06d">
      <profiles>
        <profile name="Scuttlers" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="9b1b-28bf-3224-5e14">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Tyranids with the Scuttlers biomorph gain the Scouts special rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="eb4e-8c24-758b-3f86" includeChildSelections="false" automatic="true"/>
      </constraints>
      <infoLinks>
        <infoLink name="Scouts" id="a620-9a42-53d5-debd" hidden="false" type="rule" targetId="ec7c-9e8c-06ac-06b7"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Spine Banks" hidden="false" id="8934-7502-1f9a-15f5">
      <profiles>
        <profile name="Spine Banks" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="c17e-963b-c011-1b5a">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model with spine banks counts as being equipped with frag grenades in close combat and can release a spray of spines with the same effect as a spinefist in the Shooting phase, in addition to any other weapons used.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="99c6-29cc-db61-2a60" includeChildSelections="false" automatic="true"/>
      </constraints>
      <infoLinks>
        <infoLink name="Spinefist" id="a189-b732-f731-4705" hidden="false" type="profile" targetId="8bbc-6d36-4825-3ce2"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Spore Cysts" hidden="false" id="8bc2-31d9-cd44-5b9c">
      <profiles>
        <profile name="Spore Cysts" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="07f7-bc7d-7253-dfea">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A creature with spore cysts that is not in base contact with the enemy may produce a toxin Spore Mine in the Shooting phase in addition to any other shooting. Roll a dice, on a roll of 1 the creature takes one wound with no saves allowed. Then place the Spore Mine in base contact with the creature - from this point on the Spore Mine acts as described in the Spore Mine rules.</characteristic>
          </characteristics>
        </profile>
        <profile name="Toxin Spore Mine" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="5f6a-87a3-9e5e-a3f9">
          <characteristics>
            <characteristic name="Range" typeId="52616e676523232344415441232323">-</characteristic>
            <characteristic name="Strength" typeId="537472656e67746823232344415441232323">-</characteristic>
            <characteristic name="AP" typeId="4.1502323234441545e+23">4</characteristic>
            <characteristic name="Type" typeId="8b10-045a-f593-605e">-</characteristic>
            <characteristic name="Info" typeId="33e9-27bd-77e4-401d">Toxin Spore Mines always count as having Strength equal to the target&apos;s Toughness. Therefore Toxin Mines will normally wound on a D6 roll of 4 or more. Toxin Mines can only affect vehicles which are open-topped, upon which they inflict a single glancing hit automatically.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="1a2b-9d6a-dde5-b650" includeChildSelections="false" automatic="true"/>
      </constraints>
      <infoLinks>
        <infoLink name="Spore Mines" id="7928-4f0f-b33e-a629" hidden="false" type="rule" targetId="7456-5456-bcfd-5dc2"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Symbiote Rippers" hidden="false" id="4e63-f568-1665-a384">
      <profiles>
        <profile name="Symbiote Rippers" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="e228-f321-3629-508e">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Symbiote Rippers are represented by extra Rippers glued to a creature&apos;s base. When in close combat each ripper-infested base adds one to the unit&apos;s size for outnumbering purposes (after any other modifiers).</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5d86-7bb3-9103-fb1d" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Thornback" hidden="false" id="0065-0dbc-1b30-8d19">
      <profiles>
        <profile name="Thornback" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="c880-7931-9f54-ac62">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A thornbacked creature doubles the number of models it counts as for the purposes of outnumbering if it is on the winning side in a close combat.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="2cd6-7848-a4b8-fae7" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Toxic Miasma" hidden="false" id="cea8-3c1e-23ee-9dc2">
      <profiles>
        <profile name="Toxic Miasma" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="378f-60cf-3daf-66e8">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any model being attacked by, or directing its attacks towards, a Tyranid with toxic miasma reduces its Weapon Skill by 1.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3e67-db7a-1103-f411" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Toxin Sacs (+1 S)" hidden="false" id="cfcc-2363-7202-2fea">
      <profiles>
        <profile name="Toxin Sacs (+1 S)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="128f-d8f5-139f-b77f">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A Tyranid with toxin sacs gains +1 Strength to its profile.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="1f4e-c8be-48be-7a48" includeChildSelections="false" automatic="true"/>
      </constraints>
      <modifiers>
        <modifier type="increment" value="1" field="5.323232344415441e+21" affects="profiles.Unit" scope="parent"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Tusked" hidden="false" id="ccee-9586-957b-b926">
      <profiles>
        <profile name="Tusked" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="74f2-4145-3991-b7a1">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Tusked Tyranids gain +2 Attacks when charging instead of +1.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="89a4-41f7-ac84-7e78" includeChildSelections="false" automatic="true"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Winged" hidden="false" id="f52f-f084-c7c1-fe2a">
      <profiles>
        <profile name="Winged" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="89c8-b2c9-dd23-69e8">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Winged creatures are treated as Jump Infantry in all respects. A winged model may not have the leaping or extended carapace biomorphs.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="bbac-6de3-36df-660d" includeChildSelections="false" automatic="true"/>
      </constraints>
