        <selectionEntry type="upgrade" import="true" name="Without Number" hidden="false" id="a304-9e72-07bf-4d1d">
          <rules>
            <rule name="Without Number" id="241b-fb40-6368-fe1d" hidden="false">
              <description>Any brood Without Number that is removed from play may be brought back into play at the beginning of the next Tyranid turn. It moves onto the board from the Tyranid player&apos;s board edge and has exactly the same profile and armaments as its predecessor. Victory Points are scored as usual for the brood and its replacements as if they were entirely separate broods.</description>
            </rule>
          </rules>
          <constraints>
            <constraint type="max" value="0" field="selections" scope="parent" shared="true" id="41e4-b4a6-5443-03c5" includeChildSelections="false" automatic="true"/>
            <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="5746-bb69-6c9a-c66b" includeChildSelections="false"/>
          </constraints>
          <modifiers>
            <modifier type="set" value="1" field="41e4-b4a6-5443-03c5">
              <conditions>
                <condition type="atMost" value="50" field="4deb-313d-6685-f48b" scope="parent" childId="c694-cdca-ecc3-094c" shared="true" percentValue="true" includeChildSelections="true"/>
              </conditions>
            </modifier>
            <modifier type="increment" value="3" field="4deb-313d-6685-f48b">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="model" shared="true"/>
              </conditions>
            </modifier>
          </modifiers>
        </selectionEntry>
