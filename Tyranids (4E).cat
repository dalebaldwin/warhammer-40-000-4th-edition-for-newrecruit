            <characteristic name="A" typeId="4.123232344415441e+21">2+1</characteristic>
            <characteristic name="LD" typeId="4c4423232344415441232323">10</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">5+</characteristic>
