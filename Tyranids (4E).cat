      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Warp Blast" hidden="false" id="3c8c-e03a-0b1b-fef4">
      <profiles>
        <profile name="Warp Blast" typeId="9c33-b0c8-74bd-e5a7" typeName="Psychic Power (Attack)" hidden="false" id="c627-405c-2aba-bce6">
          <characteristics>
            <characteristic name="Range" typeId="5bf6-378a-0cb7-b079">24&quot;</characteristic>
            <characteristic name="Strength" typeId="12da-9b3e-f37b-bc35">5</characteristic>
            <characteristic name="AP" typeId="10b5-aa5b-ccde-79cc">3</characteristic>
            <characteristic name="Type" typeId="20e7-cbcb-1781-a732">Assault 1, Blast</characteristic>
            <characteristic name="Details" typeId="a812-390d-dff6-dabd"/>
          </characteristics>
        </profile>
        <profile name="Warp Blast (Focused)" typeId="9c33-b0c8-74bd-e5a7" typeName="Psychic Power (Attack)" hidden="false" id="aaaa-f359-bc8c-a79e">
          <characteristics>
            <characteristic name="Range" typeId="5bf6-378a-0cb7-b079">18&quot;</characteristic>
            <characteristic name="Strength" typeId="12da-9b3e-f37b-bc35">10</characteristic>
            <characteristic name="AP" typeId="10b5-aa5b-ccde-79cc">2</characteristic>
            <characteristic name="Type" typeId="20e7-cbcb-1781-a732">Assault 1</characteristic>
            <characteristic name="Details" typeId="a812-390d-dff6-dabd">A focused warp blast requires the creature to pass a Psychic test. A focused warp blast my not be used by a Tyranid with Enhanced Senses.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="true" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="c7bc-0c96-23df-f709" shared="true" includeChildSelections="true"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="7823-fc82-6bcb-20ef" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Warp Field" hidden="false" id="f4f9-7eee-0a6a-5df0">
      <profiles>
        <profile name="Warp Field" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="c5fd-7584-b420-7a44">
          <characteristics>
            <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Defensive psychic barriers give the creature a 2+ Armour Save and a 6+ Invulnerable Save. The Armour Save bonus does not stack with Extended Carapace</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f8ec-4d3e-159d-8cdc" includeChildSelections="false"/>
      </constraints>
      <modifiers>
        <modifier type="set" value="2+" field="5.361766523232344e+27" scope="parent" affects="profiles.Unit"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Bonesword " hidden="false" id="e71c-f552-a25c-7b66">
      <profiles>
        <profile name="Bonesword" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="cc28-3a78-da8b-a4bd">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Hive Tyrant with a Bonesword is permanently under the effects of the Catalyst power. With a successful Psychic test taken at the beginning of the Tyranid Assault phase, the Hive Tyrant may use the Bonesword to extend the effects of Catalyst to all broods with a model within 6&quot;.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Close Combat Biomorph" id="ef8c-d590-98d9-961f" hidden="false" type="rule" targetId="42c0-5486-5159-916f"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Crushing Claws" hidden="false" id="f6b3-de8e-1595-6464">
      <profiles>
        <profile name="Crushing Claws" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="5af8-e108-b629-69f3">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A model with crushing claws substitutes a D6 for its normal number of attacks. Any bonus attacks, for example, for charging, scything talons, etc, are added to the D6 roll. Fore determining the number of ranged bio-weapon shots the creature has, use its basic number of attacks.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Close Combat Biomorph" id="2d2c-d9da-05c2-c8ba" hidden="false" type="rule" targetId="42c0-5486-5159-916f"/>
      </infoLinks>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="4b55-50f5-6feb-3cb4" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Twin-linked" hidden="false" id="e4fc-6ee2-d737-aaae">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="df0b-cb72-41b8-fe97" includeChildSelections="false"/>
      </constraints>
      <modifiers>
        <modifier type="append" value="Twin-linked" field="8b10-045a-f593-605e" scope="parent" affects="self.entries.profiles.Weapon" join=", "/>
        <modifier type="multiply" value="2" field="4deb-313d-6685-f48b" scope="parent" join=", "/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Winged" hidden="false" id="f3f6-6d57-f13e-cef4">
      <profiles>
        <profile name="Winged" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="1abe-12e5-322a-b899">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Winged creatures are treated as Jump Infantry in all respects. A winged model may not have the leaping or extended carapace biomorphs.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d4d3-4298-2f1f-644b" includeChildSelections="false" automatic="true"/>
      </constraints>
      <modifiers>
        <modifier type="append" value="Jump Infantry" field="556e6974205479706523232344415441232323" scope="parent" affects="profiles.Unit" join=", "/>
      </modifiers>
      <comment>For Hive Tyrants</comment>
    </selectionEntry>
  </sharedSelectionEntries>
