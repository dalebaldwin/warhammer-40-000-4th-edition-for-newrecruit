      <infoLinks>
        <infoLink name="Litanies of Hate" id="149a-3bfa-4791-0488" hidden="false" type="rule" targetId="99d7-eaaa-fb97-4d39"/>
        <infoLink name="Honour of the Chapter" id="27fd-843e-009c-071a" hidden="false" type="rule" targetId="9cb2-4889-4b6c-190d"/>
      </infoLinks>
      <rules>
        <rule name="Iron-Willed" id="bbba-5be4-fe05-c2cc" hidden="false">
          <description>As soon as he is in close combat Lemartes must take a Leadership test. If he passes, he has D3+3 attacks that phase. If he fails he only has D3 attacks that phase as he as forced to clamp down on his raging bloodthirst. This already includes the bonus attack for his two close combat weapons, but Lemartes still gains the normal +1 Attack if he charges.</description>
        </rule>
        <rule name="Rigid Discipline" id="9228-772c-3552-5187" hidden="false">
          <description>Any Blood Angels unit within 6&quot;&apos; of Lemartes can re-roll the D6 when testing to restrain themselves at the start of the turn. If the second roll is also a 1, the unit must move towards the enemy as normal.</description>
        </rule>
      </rules>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="3b2c-0b34-0455-a75c" includeChildSelections="true"/>
      </constraints>
    </selectionEntry>
