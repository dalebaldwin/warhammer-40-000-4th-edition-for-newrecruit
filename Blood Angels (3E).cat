        <entryLink import="true" name="Psychic Hood" hidden="false" id="f96a-0a9e-5e02-3013" type="selectionEntry" targetId="3ec1-9875-7ae9-0f90" sortIndex="4"/>
        <entryLink import="true" name="Blood Angels Honour Guard" hidden="false" id="cd87-3008-73f7-4481" type="selectionEntry" targetId="fabc-5c51-ed3a-b9f5"/>
      </entryLinks>
      <rules>
        <rule name="Transfixing Glare" id="42c6-696f-b00a-7d05" hidden="false">
          <description>Any model in base contact with Mephiston in close combat must take a Leadership test (with the model&apos;s own Leadership with no bonuses or penalties). If it is passed, the model can attack normally. If it is failed the model counts as having a Weapon Skill of 1 for the rest of that round. Test each turn for each model in contact with Mephiston.</description>
        </rule>
        <rule name="Blood Fever" id="befa-8a73-0044-b710" hidden="false">
          <description>If Mephiston&apos;s close combat opponents break, he must take a normal Leadership test on 2D6. if he passes, then he advances as normal. If he fails then he stops to quench is ravening bloodthirst and cannot move at all.</description>
        </rule>
      </rules>
    </selectionEntry>
