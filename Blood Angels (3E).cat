      <rules>
        <rule name="Elites" id="dddf-908d-3fae-b9e0" hidden="false" noindex="true">
          <description>The Death Company is deployed as Elites in scenarios where this is relevant.</description>
        </rule>
        <rule name="The Red Thirst" id="c41b-b23e-b4a9-0b46" hidden="false">
          <description>The only characters who may lead a Death Company unit are Blood Angels Chaplains or a Sanguinary High Priest (providing, of course, that he does not have an Honour Guard). A Death Company which is not lead by a Blood Angels Chaplain or Sanguinary High Priest must move towards the nearest enemy unit as fast as possible and must make an assault if it can do so.</description>
        </rule>
      </rules>
    </selectionEntry>
